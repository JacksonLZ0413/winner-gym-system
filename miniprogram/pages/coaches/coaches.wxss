.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  padding: 8rpx 0;
}

.search-icon {
  font-size: 32rpx;
  margin-left: 16rpx;
}

.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  color: #fff;
}

.coach-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coach-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.coach-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star {
  color: #ffc107;
  font-size: 28rpx;
}

.rating-value {
  font-size: 28rpx;
  color: #ffc107;
  font-weight: bold;
}

.specialty {
  font-size: 26rpx;
  color: #1989fa;
  margin-bottom: 8rpx;
}

.bio {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.experience {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.exp-icon {
  font-size: 28rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #f56c6c;
}

.price-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #f56c6c;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}