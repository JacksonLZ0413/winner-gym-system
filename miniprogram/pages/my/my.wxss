.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  color: #fff;
}

.not-login {
  padding: 100rpx 40rpx;
}

.not-login-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.not-login-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.not-login-text {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1989fa;
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0;
}

.avatar-wrapper {
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar text {
  font-size: 48rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 26rpx;
  opacity: 0.8;
}

.logout-btn {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  font-size: 26rpx;
}

.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: -24rpx 20rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #1989fa;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-value {
  font-size: 28rpx;
  color: #1989fa;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.version {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}