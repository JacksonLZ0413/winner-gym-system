<view class="container">
  <view class="user-card" wx:if="{{userInfo}}">
    <view class="avatar-wrapper">
      <view class="avatar">
        <text>{{userInfo.name && userInfo.name.charAt(0) || '?'}}</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name}}</text>
      <text class="user-role">会员</text>
    </view>
    <view class="logout-btn" bindtap="logout">退出</view>
  </view>

  <view class="not-login" wx:else>
    <view class="not-login-card">
      <view class="not-login-icon">👤</view>
      <text class="not-login-text">请先登录</text>
      <button class="login-btn" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <view class="stats-card" wx:if="{{userInfo}}">
    <view class="stat-item" bindtap="goToBookings">
      <text class="stat-value">{{stats.totalBookings}}</text>
      <text class="stat-label">总预约</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.confirmedBookings}}</text>
      <text class="stat-label">已确认</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.completedBookings}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <view class="menu-list" wx:if="{{userInfo}}">
    <view class="menu-item" bindtap="goToBookings">
      <text class="menu-icon">📅</text>
      <text class="menu-text">我的预约</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCoaches">
      <text class="menu-icon">👨‍🏫</text>
      <text class="menu-text">预约教练</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">🎯</text>
      <text class="menu-text">课程配额</text>
      <text class="menu-value">{{userInfo && userInfo.course_quota > 0 ? userInfo.remain_quota + '/' + userInfo.course_quota : '无限制'}}</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">📱</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="version" wx:if="{{userInfo}}">
    <text>版本 1.0.0</text>
  </view>
</view>