<view class="container">
  <view class="header">
    <text class="title">健身房预约</text>
    <text class="subtitle">会员注册</text>
  </view>
  
  <view class="form">
    <view class="form-item">
      <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请输入姓名" bindinput="onNameInput" value="{{name}}" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请输入密码（至少6位）" password="{{true}}" bindinput="onPasswordInput" value="{{password}}" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请确认密码" password="{{true}}" bindinput="onConfirmPasswordInput" value="{{confirmPassword}}" />
    </view>
    <button class="btn-register" bindtap="doRegister" loading="{{loading}}">注册</button>
    <view class="footer">
      <text>已有账号？</text>
      <text class="link" bindtap="goToLogin">立即登录</text>
    </view>
  </view>
</view>
