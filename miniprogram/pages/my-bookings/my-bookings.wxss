.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  color: #fff;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.coach-info {
  display: flex;
  align-items: center;
}

.coach-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.coach-detail {
  display: flex;
  flex-direction: column;
}

.coach-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.course-name {
  font-size: 26rpx;
  color: #999;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-badge.warning {
  background: #fff7e6;
  color: #e6a23c;
}

.status-badge.success {
  background: #f0f9ff;
  color: #1989fa;
}

.status-badge.danger {
  background: #fef0f0;
  color: #f56c6c;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #f56c6c;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.action-btn.rate {
  background: #1989fa;
  color: #fff;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
  display: block;
}

.rating-section {
  margin-bottom: 24rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.stars {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 56rpx;
  color: #ddd;
  transition: all 0.3s;
}

.star.active {
  color: #ffc107;
}

.review-section {
  margin-bottom: 32rpx;
}

.review-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.review-input {
  width: 100%;
  height: 200rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-actions .btn-secondary,
.modal-actions .btn-primary {
  flex: 1;
}