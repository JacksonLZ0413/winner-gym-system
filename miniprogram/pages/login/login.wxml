<view class="container">
  <view class="header">
    <text class="title">健身房预约</text>
    <text class="subtitle">会员登录</text>
  </view>
  
  <view class="form">
    <view class="form-item">
      <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请输入密码" password="{{true}}" bindinput="onPasswordInput" value="{{password}}" />
    </view>
    <button class="btn-login" bindtap="doLogin" loading="{{loading}}">登录</button>
    <view class="footer">
      <text>没有账号？</text>
      <text class="link" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
</view>
