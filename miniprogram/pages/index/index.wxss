.banner {
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #f0f7ff 0%, #e0ebff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.card-more {
  font-size: 26rpx;
  color: #1989fa;
}

.coach-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coach-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.coach-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1989fa 0%, #007aff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.coach-info {
  flex: 1;
}

.coach-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.coach-specialty {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.coach-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star {
  color: #ffc107;
  font-size: 24rpx;
}

.rating-count {
  color: #999;
  font-size: 22rpx;
}

.coach-price {
  text-align: right;
}

.price-symbol {
  font-size: 24rpx;
  color: #f56c6c;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #f56c6c;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

.course-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.course-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0;
  background: #fafafa;
  border-radius: 12rpx;
}

.course-icon {
  font-size: 48rpx;
}

.course-name {
  font-size: 26rpx;
  color: #666;
}

.tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #666;
}